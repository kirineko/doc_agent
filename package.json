{
  "name": "doc-agent",
  "private": true,
  "version": "2026.6.27",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle:js": "node scripts/copy-markdown-vendor.mjs && node scripts/bundle-js-libs.mjs",
    "vendor:markdown": "node scripts/copy-markdown-vendor.mjs",
    "calver:today": "node scripts/calver-today.mjs",
    "release:check": "npm run vendor:markdown && npm run bundle:js && cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings && cargo test && cd .. && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "4.4.0",
    "@marp-team/marp-core": "^4.0.0",
    "@marp-team/marpit": "^3.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.8",
    "docx": "^9.5.0",
    "esbuild": "^0.25.0",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "katex": "^0.16.22",
    "marked": "^15.0.12",
    "mermaid": "^11.6.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
