{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocAgent",
  "version": "2026.6.17",
  "identifier": "com.kirineko.doc-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Doc Agent",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' ipc: http://ipc.localhost asset: http://asset.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "script-src": "'self' 'unsafe-inline' http://localhost:1420"
      },
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "resources": {
      "pdfium/": "pdfium/",
      "fonts/": "fonts/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwQTNCNDQ0RkFGNUQ2MgpSV1JpWGE5UFJEc0tBeWh6YndYeHdBRno3UmczZGZyRGNvSXJ0Mm45eTZMdUdyU0VvQUlMSUI1Mgo=",
      "endpoints": [
        "https://doc-agent.oss-cn-guangzhou.aliyuncs.com/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
